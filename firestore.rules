rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar: Verifica si el usuario está logueado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Función auxiliar: Obtiene los datos del usuario que está haciendo la petición
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Función auxiliar: Verifica si el usuario actual es el FUNDADOR (SaaS SuperAdmin)
    function isOwner() {
      return getUserData().role == 'owner';
    }

    // ---------------------------------------------------------
    // Colección: TENANTS (Empresas Inmobiliarias Clientes)
    // ---------------------------------------------------------
    match /tenants/{tenantId} {
      // Un owner (SuperAdmin) puede leer y escribir todas las empresas
      // Cualquier empleado de la empresa puede leer los datos de SU empresa
      allow read: if isAuthenticated() && (isOwner() || getUserData().tenantId == tenantId);
      
      // SOLO el owner (SuperAdmin Daniel Balarezo) puede crear o editar empresas
      allow write: if isAuthenticated() && isOwner();

      match /schema_lead/{fieldId} {
        allow read: if isAuthenticated() && (isOwner() || getUserData().tenantId == tenantId);
        allow write: if isAuthenticated() && (isOwner() || (getUserData().tenantId == tenantId && getUserData().role == 'manager'));
      }

      match /roles/{roleId} {
        allow read: if isAuthenticated() && (isOwner() || getUserData().tenantId == tenantId);
        allow write: if isAuthenticated() && (isOwner() || (getUserData().tenantId == tenantId && getUserData().role == 'manager'));
      }
    }

    // ---------------------------------------------------------
    // Colección: USERS (Usuarios / Empleados)
    // ---------------------------------------------------------
    match /users/{userId} {
      // LECTURA:
      // - El owner lee todo
      // - Un usuario puede ver su propio perfil
      // - Un manager o agent pueden ver a los usuarios de su propia inmobiliaria
      allow read: if isAuthenticated() && (
        isOwner() || 
        request.auth.uid == userId || 
        getUserData().tenantId == resource.data.tenantId
      );
      
      // ESCRITURA:
      // - El owner escribe todo (Crear, suspender, borrar)
      // - El propio usuario puede editar sus datos
      // - Un manager puede crear/editar usuarios de su misma empresa
      allow write: if isAuthenticated() && (
        isOwner() || 
        request.auth.uid == userId ||
        (
          getUserData().role == 'manager' &&
          (resource == null || getUserData().tenantId == resource.data.tenantId) &&
          (request.resource == null || getUserData().tenantId == request.resource.data.tenantId)
        )
      );
    }

    // ---------------------------------------------------------
    // Colección: PROJECTS (Proyectos Inmobiliarios)
    // ---------------------------------------------------------
    match /projects/{projectId} {
      // LECTURA: Owner lee todo. Manager/Agent leen solo los de su empresa.
      allow read: if isAuthenticated() && (
        isOwner() || 
        getUserData().tenantId == resource.data.tenantId
      );
      
      // ESCRITURA: Owner escribe todo. Manager puede editar los proyectos de su empresa.
      allow write: if isAuthenticated() && (
        isOwner() || 
        (getUserData().tenantId == request.resource.data.tenantId && getUserData().role == 'manager')
      );
    }

    // ---------------------------------------------------------
    // Colección: LEADS (Prospectos y Cotizaciones)
    // ---------------------------------------------------------
    match /leads/{leadId} {
      // LECTURA: 
      // - Owner: Lee TODOS los leads de todas las empresas.
      // - Manager: Lee TODOS los leads de SU empresa.
      // - Asesor: Lee SOLO los leads asignados a él dentro de su empresa.
      allow read: if isAuthenticated() && (
        isOwner() || 
        (
          getUserData().tenantId == resource.data.tenantId && 
          (
            getUserData().role == 'manager' || 
            resource.data.assignedTo == request.auth.uid
          )
        )
      );
      
      // ESCRITURA:
      // - Owner: Escribe en todos lados.
      // - Manager: Crea/Edita cualquier lead de su empresa.
      // - Asesor: Crea leads para sí mismo, o edita los que ya tiene asignados.
      allow create: if isAuthenticated() && (
        isOwner() ||
        (
          getUserData().tenantId == request.resource.data.tenantId && 
          (
            getUserData().role == 'manager' || 
            request.resource.data.assignedTo == request.auth.uid
          )
        )
      );

      allow update: if isAuthenticated() && (
        isOwner() ||
        (
          getUserData().tenantId == resource.data.tenantId && 
          getUserData().tenantId == request.resource.data.tenantId && // Evita que lo transfieran a otra empresa
          (
            getUserData().role == 'manager' || 
            resource.data.assignedTo == request.auth.uid
          )
        )
      );

      allow delete: if isAuthenticated() && (
        isOwner() ||
        (
          getUserData().tenantId == resource.data.tenantId && 
          (
            getUserData().role == 'manager' || 
            resource.data.assignedTo == request.auth.uid
          )
        )
      );
    }

    // ---------------------------------------------------------
    // Colección: LEAD ACTIVITIES (Actividades de Prospectos)
    // ---------------------------------------------------------
    match /lead_activities/{activityId} {
      allow read: if isAuthenticated() && (
        isOwner() || 
        (resource == null) ||
        getUserData().tenantId == resource.data.tenantId
      );
      
      allow write: if isAuthenticated() && (
        isOwner() || 
        (request.resource != null && getUserData().tenantId == request.resource.data.tenantId) ||
        (resource != null && getUserData().tenantId == resource.data.tenantId)
      );
    }

    // ---------------------------------------------------------
    // Colección: INVENTORY (Unidades / Lotes)
    // ---------------------------------------------------------
    match /inventory/{unitId} {
      allow read: if isAuthenticated() && (
        isOwner() || 
        getUserData().tenantId == resource.data.tenantId
      );
      
      allow write: if isAuthenticated() && (
        isOwner() || 
        (getUserData().tenantId == request.resource.data.tenantId && getUserData().role == 'manager') ||
        (getUserData().tenantId == resource.data.tenantId && getUserData().role == 'manager')
      );
    }

    // ---------------------------------------------------------
    // Colección: PAYMENTS (Pagos y Vouchers)
    // ---------------------------------------------------------
    match /payments/{paymentId} {
      // LECTURA: Owner lee todo. Usuarios de la empresa leen los pagos de su empresa.
      allow read: if isAuthenticated() && (
        isOwner() || 
        (resource == null) ||
        getUserData().tenantId == resource.data.tenantId
      );
      
      // ESCRITURA: 
      allow write: if isAuthenticated() && (
        isOwner() || 
        (getUserData().tenantId == request.resource.data.tenantId)
      );
    }

    // ---------------------------------------------------------
    // Colección: CONTRACT TEMPLATES (Plantillas)
    // ---------------------------------------------------------
    match /contract_templates/{templateId} {
      allow read: if isAuthenticated() && (
        isOwner() || 
        (resource == null) ||
        getUserData().tenantId == resource.data.tenantId
      );
      allow write: if isAuthenticated() && (
        isOwner() || 
        (getUserData().tenantId == request.resource.data.tenantId && getUserData().role == 'manager') ||
        (getUserData().tenantId == resource.data.tenantId && getUserData().role == 'manager')
      );
    }

    // ---------------------------------------------------------
    // Colección: AUDIT LOGS (Registro de Auditoría)
    // ---------------------------------------------------------
    match /audit_logs/{logId} {
      // LECTURA: Owner lee todo. Managers leen los de su empresa.
      allow read: if isAuthenticated() && (
        isOwner() || 
        (getUserData().tenantId == resource.data.tenantId && getUserData().role == 'manager')
      );
      
      // CREACIÓN: Cualquier usuario autenticado de la empresa puede crear un log.
      allow create: if isAuthenticated() && (
        isOwner() || 
        getUserData().tenantId == request.resource.data.tenantId
      );

      // INMUTABILIDAD: Nadie puede actualizar ni eliminar un registro de auditoría.
      allow update, delete: if false;
    }

    // ---------------------------------------------------------
    // Colección: WORKFLOWS (Automatizaciones)
    // ---------------------------------------------------------
    match /workflows/{workflowId} {
      allow read: if isAuthenticated() && (
        isOwner() || 
        (resource == null) ||
        getUserData().tenantId == resource.data.tenantId
      );
      // Solo owner o manager pueden crear/modificar workflows
      allow write: if isAuthenticated() && (
        isOwner() || 
        (request.resource != null && getUserData().tenantId == request.resource.data.tenantId && getUserData().role == 'manager') ||
        (resource != null && getUserData().tenantId == resource.data.tenantId && getUserData().role == 'manager')
      );
    }
    // ---------------------------------------------------------
    // Colección: METADATA (Datos internos del sistema, ej. índices Round Robin)
    // ---------------------------------------------------------
    match /metadata/{tenantId} {
      // Todos los de la empresa pueden leer para ejecutar lógica
      allow read: if isAuthenticated() && (
        isOwner() || 
        getUserData().tenantId == tenantId
      );
      // Todos los de la empresa pueden escribir para actualizar índices como el Round Robin
      allow write: if isAuthenticated() && (
        isOwner() || 
        getUserData().tenantId == tenantId
      );
    }
  }
}
